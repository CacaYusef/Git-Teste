if(!require(pacman)) install.packages("pacman")
pacman::p_load(dados, dplyr, janitor, vioplot, ggplot2, tidyverse)
plot(avioes$motores, avioes$velocidade)
#plot customizando eixos
plot(avioes$motores, avioes$velocidade, xlab = "quantidade de motores", ylab = "velocidade")
#plot configurando os valores maximos dos eixos
plot(avioes$motores, avioes$velocidade, xlab = "quantidade de motores", ylab = "velocidade",
xlim = c(1, 4), ylim = c(50, 500))
# Removendo a caixa que circunda o plot
plot(avioes$motores, avioes$velocidade, xlab = "quantidade de motores", ylab = "velocidade",
xlim = c(1, 4), ylim = c(50, 500),  col = "dodgerblue1",  pch = 18, cex = 1.2, las = 3,  tcl  = -0.4, bg = "black")
# enfim, para entender todas as possibilidades, bastar mudar os valores e ver o que acontece caralho
# Para entender plots mais avançados com cenários simultaneos, consultar "an introduction to R" cap 4.3
# Aprendendo ggplot ----
library(readxl)
yaounde_data <- read_excel("C:/Users/Cacob/OneDrive/Área de Trabalho/R scripts Course/data/yaounde_data.xlsx")
ggplot(yaounde_data)
# Setando grafico para o plot das coisas   (OBS, FIZ MERDA NESSE DIA E PERDI MUITO PROGRESSO NOS CODIGOS
# QUALQUER COISA, REVER PROFUNDAMENTE CAPITULO 5 LIVRO AND INTRODUCTION TO R)
yaounde_data_renamed <-
yaounde_data %>%
rename("weight" = "weight_kg") %>%
slice_sample( n = 100)
ggplot(mapping = aes(x = age, y = weight), data = yaounde_data_renamed)
+ geom_point() +
geom_smooth( method = "lm", se = FALSE)
if (!require(pacman)) install.packages("pacman")
pacman::p_load(tidyverse, forcats, lubridate)
install.packages("esquisse")
mtcars %>%
group_by(cyl) %>%
summarise(avg = mean(mpg), count = n()) %>%
ungroup () %>%
mutate(sum(count)) %>%
mutate(proporções = count/ sum(count)*100)
dplyr::starwars %>%
filter(!is.na(height)) %>%
filter(!is.na(mass)) %>%
filter(!is.na(hair_color)) %>%
ggplot(aes(x = mass, y = height, colour = eye_color)) +
geom_point(shape = "square", size = 1.5) +
geom_smooth( method = "lm", se = FALSE)
geom_rug(size = 1.5) +
scale_color_hue(direction = 1, name = 'teste') +
labs(title = "gráfico aleatório feio") +
#ggthemes::theme_excel() +
facet_wrap(vars(gender))
